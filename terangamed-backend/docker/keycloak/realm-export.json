          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["ADMIN"]
    },
    {
      "id": "aaaaaaaa-aaaa-aaaa-aaaa-aaaa00000001",
      "username": "dr.martin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Jean",
      "lastName": "Martin",
      "email": "jean.martin@terangamed.local",
      "credentials": [
        {
          "type": "password",
