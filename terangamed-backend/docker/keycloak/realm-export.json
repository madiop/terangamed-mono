{
  "realm": "terangamed",
  "displayName": "TerangaMed",
  "displayNameHtml": "<strong>TerangaMed — Cabinet médical</strong>",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "rememberMe": true,
  "verifyEmail": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,

  "accessTokenLifespan": 1800,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,

  "internationalizationEnabled": true,
  "supportedLocales": ["fr", "en"],
  "defaultLocale": "fr",

  "roles": {
    "realm": [
      {
        "name": "ADMIN",
        "description": "Administrateur — accès complet à toutes les ressources et configurations"
      },
      {
        "name": "DOCTOR",
        "description": "Médecin — gestion des dossiers médicaux de ses patients, consultations, prescriptions"
      },
      {
        "name": "RECEPTIONIST",
        "description": "Réceptionniste — gestion patients, rendez-vous, facturation (sans accès dossiers médicaux)"
      },
      {
        "name": "PATIENT",
        "description": "Patient — accès en lecture à son propre dossier médical (matching via Keycloak sub)"
      }
    ]
  },

  "defaultRoles": ["uma_authorization", "offline_access"],

  "clients": [
    {
      "clientId": "terangamed-frontend",
      "name": "TerangaMed Frontend (Angular SPA)",
      "description": "Application Angular du cabinet — Authorization Code Flow + PKCE",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "http://localhost:4200/*",
        "http://localhost:8080/*",
        "http://localhost:8081/*",
        "http://localhost:8082/*",
        "http://localhost:8083/*",
        "http://localhost:8084/*",
        "http://localhost:8085/*",
        "http://localhost:8086/*"
      ],
      "webOrigins": [
        "http://localhost:4200",
        "http://localhost:8080",
        "+"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:4200/*##http://localhost:8080/*",
        "access.token.lifespan": "1800",
        "use.refresh.tokens": "true"
      },
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "protocolMappers": [
        {
          "name": "audience-terangamed-backend",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "terangamed-backend",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "terangamed-backend",
      "name": "TerangaMed Backend (audience claim + service account)",
      "description": "Cible d'audience pour les JWT issus du frontend ; sert aussi au flow client_credentials pour les jobs / consumers Kafka",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "fullScopeAllowed": true,
      "secret": "terangamed-backend-secret-CHANGE-ME-IN-PROD",
      "attributes": {
        "access.token.lifespan": "1800",
        "client.secret.creation.time": "1735689600"
      },
      "defaultClientScopes": [
        "profile",
        "roles",
        "email"
      ]
    },
    {
      "clientId": "swagger-ui",
      "name": "Swagger UI (test des APIs)",
      "description": "Authentification OAuth2 dans les UIs Swagger de chaque microservice",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "http://localhost:8080/swagger-ui/oauth2-redirect.html",
        "http://localhost:8081/swagger-ui/oauth2-redirect.html",
        "http://localhost:8082/swagger-ui/oauth2-redirect.html",
        "http://localhost:8083/swagger-ui/oauth2-redirect.html",
        "http://localhost:8084/swagger-ui/oauth2-redirect.html",
        "http://localhost:8085/swagger-ui/oauth2-redirect.html",
        "http://localhost:8086/swagger-ui/oauth2-redirect.html",
        "http://localhost:8080/webjars/springdoc-openapi-ui/oauth2-redirect.html"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "http://localhost:8081",
        "http://localhost:8082",
        "http://localhost:8083",
        "http://localhost:8084",
        "http://localhost:8085",
        "http://localhost:8086",
        "+"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "access.token.lifespan": "3600"
      },
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email"
      ],
      "protocolMappers": [
        {
          "name": "audience-terangamed-backend",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "terangamed-backend",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],

  "users": [
