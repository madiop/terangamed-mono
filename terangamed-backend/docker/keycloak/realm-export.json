        "license_number": ["MED-2024-0001"]
      }
    },
    {
      "username": "reception",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Aïssatou",
      "lastName": "Diop",
      "email": "aissatou.diop@terangamed.local",
      "credentials": [
        {
          "type": "password",
