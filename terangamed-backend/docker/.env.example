# ─────────────────────────────────────────────────────────────────────────────
# TerangaMed — Variables d'environnement Docker Compose
# Copier en .env et adapter localement (le fichier .env est gitignoré).
# ─────────────────────────────────────────────────────────────────────────────

# ─── Ports HÔTE (changer si déjà occupés sur votre machine) ──────────────────
# Les ports INTERNES (utilisés par les services entre eux dans le réseau Docker)
# restent fixes ; seuls les ports exposés à l'hôte sont configurables.
#
# Exemple : si vous avez déjà PostgreSQL en local sur 5432, mettez :
#   POSTGRES_HOST_PORT=5433
# puis connectez-vous depuis l'hôte avec : psql -h localhost -p 5433 -U terangamed
#
POSTGRES_HOST_PORT=5432
POSTGRES_BIND_HOST=127.0.0.1

KEYCLOAK_HOST_PORT=8180
KEYCLOAK_BIND_HOST=127.0.0.1

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=terangamed
POSTGRES_PASSWORD=terangamed

# ─── Keycloak admin ──────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ─── Eureka ──────────────────────────────────────────────────────────────────
EUREKA_USER=eureka
EUREKA_PASSWORD=eureka

# ─── Config Server ───────────────────────────────────────────────────────────
CONFIG_SERVER_USER=config
CONFIG_SERVER_PASSWORD=config

# ─── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:4200

# ─── Kafka (étape 8) ─────────────────────────────────────────────────────────
# Port Kafka exposé à l'hôte (clients externes — IDE, kafka-cli local).
# Les services internes au réseau Docker utilisent kafka:9092 (PLAINTEXT).
KAFKA_HOST_PORT=29092
KAFKA_BIND_HOST=127.0.0.1

# Schema Registry (Avro)
SCHEMA_REGISTRY_HOST_PORT=8085
SCHEMA_REGISTRY_BIND_HOST=127.0.0.1

# Kafka UI (Provectus) — interface web de debug
KAFKA_UI_HOST_PORT=8090
KAFKA_UI_BIND_HOST=127.0.0.1

# Cluster ID pour KRaft mode — base64 d'un UUID, doit être STABLE entre redémarrages
# Pour en générer un nouveau : kafka-storage random-uuid
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# ─── MinIO (stockage objet pour PDFs d'ordonnances) ──────────────────────────
# Service S3-compatible utilisé par medical-record-service pour stocker les
# ordonnances PDF générées (cache idempotent par hash de contenu).
#
# ⚠️ Changer MINIO_ROOT_PASSWORD en production (longueur min. 8, complexité forte).
# Le bucket "terangamed-prescriptions" est créé automatiquement au démarrage de
# medical-record-service — pas besoin de pré-création manuelle.
MINIO_ROOT_USER=terangamed
MINIO_ROOT_PASSWORD=terangamed-secret-2026
MINIO_PRESCRIPTION_BUCKET=terangamed-prescriptions

# Ports exposés à l'hôte (API S3 + Console web admin)
# Console MinIO accessible sur http://localhost:9001 (login = MINIO_ROOT_USER/PASSWORD)
MINIO_API_HOST_PORT=9000
MINIO_API_BIND_HOST=127.0.0.1
MINIO_CONSOLE_HOST_PORT=9001
MINIO_CONSOLE_BIND_HOST=127.0.0.1

# ─── En-tête cabinet sur ordonnances PDF ─────────────────────────────────────
# Override par déploiement (= chaque cabinet client). Ces valeurs apparaissent
# dans le bandeau supérieur de chaque ordonnance imprimée.
CLINIC_NAME=Cabinet Médical TerangaMed
CLINIC_ADDRESS_1=Avenue Cheikh Anta Diop
CLINIC_ADDRESS_2=Dakar, Sénégal
CLINIC_PHONE=+221 33 000 00 00
CLINIC_EMAIL=contact@terangamed.sn

# URL publique utilisée pour le QR code de vérification d'ordonnance.
# En prod : https://app.terangamed.sn (ou domaine du cabinet).
PUBLIC_BASE_URL=http://localhost:4200
