{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "../out-tsc/e2e",
    "module": "commonjs",
    "target": "ES2022",
    "types": ["node"],
    "lib": ["ES2022", "dom"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noPropertyAccessFromIndexSignature": false
  },
  "include": ["**/*.ts"]
}
