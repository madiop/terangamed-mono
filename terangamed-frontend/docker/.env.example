# ─────────────────────────────────────────────────────────────────────────────
# TerangaMed — Frontend stack — variables d'environnement
#
# Usage :
#   cp .env.example .env       # une seule fois
#   # éditer .env selon ton environnement
#   docker compose up -d
#
# Toutes les variables ont des defaults raisonnables pour le mode "même hôte
# que le backend" (terangamed-net Docker). Surcharger uniquement si besoin.
# ─────────────────────────────────────────────────────────────────────────────

# ─── URL de l'API Gateway ────────────────────────────────────────────────────
# Le frontend (Nginx) reverse-proxy `/api/*` vers cette URL. Default = nom
# DNS Docker dans le réseau terangamed-net partagé avec le backend.
#
# Exemples de surcharge :
#   - Vers un backend remote : API_BACKEND_URL=https://api.staging.example.com
#   - Vers un backend local hors Docker : API_BACKEND_URL=http://host.docker.internal:8080
API_BACKEND_URL=http://api-gateway:8080

# ─── Bind du port Nginx sur l'hôte ──────────────────────────────────────────
# Par défaut, Nginx est exposé uniquement à la machine locale (127.0.0.1).
# Pour exposer au LAN (test depuis un autre device), passer à 0.0.0.0.
# ⚠️ Ne JAMAIS exposer 0.0.0.0 sans firewall en prod.
FRONTEND_BIND_HOST=127.0.0.1

# Port host. Par défaut 4200 (cohérent avec `ng serve` dev mode + déjà
# autorisé dans webOrigins du realm Keycloak). Changer si conflit avec un
# `ng serve` qui tourne en parallèle.
FRONTEND_HOST_PORT=4200
